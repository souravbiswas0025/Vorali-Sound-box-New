<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_permissions"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/volume_label"
        android:textSize="18sp" />

    <SeekBar
        android:id="@+id/volumeSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="100"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/sound_choice_label"
        android:textSize="18sp" />

    <RadioGroup
        android:id="@+id/soundRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <RadioButton
            android:id="@+id/radioBell"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sound_bell"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/radioWhistle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sound_whistle" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_waiting"
        android:textSize="16sp"
        android:textColor="#888888"
        android:layout_marginTop="32dp"/>

</LinearLayout>